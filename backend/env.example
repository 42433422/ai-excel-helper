# FHD 后端 — 复制为 .env 或按部署平台注入环境变量

# 必填：PostgreSQL（禁止使用 sqlite: 连接串）
# DATABASE_URL=postgresql+psycopg://xcagi:xcagi@127.0.0.1:5432/xcagi

# --- 可选：Mod 门禁 + 连接串加密（见 backend/shell/mod_database_gate.py）---
# 仅当 fhd_shell_mods.json（或 FHD_SHELL_MODS_JSON）列出的 mod id 全部包含下列 id 时，才允许读取 DATABASE_URL / 建连。
# FHD_DB_MOD_GATE=my-core-mod,another-mod
# 门禁未通过时，将 DATABASE_URL 加密写入文件并删除环境变量明文（须 cryptography + 密钥）：
# FHD_DB_URL_ENCRYPT_ON_GATE_FAIL=1
# FHD_DB_GATE_SECRET=change-me-long-random-secret
# FHD_DB_URL_CIPHER_FILE=E:/FHD/workspace/.fhd_dburl.fernet
# fhd_shell_mods.json / XCAGI/mods/*/manifest.json 中数据库种子（门禁通过后、核心表初始化后执行；按路径幂等一次）：
# - "database_seed_sql": "database/seed.sql"   # 相对 mod 目录或绝对路径
# - "database_seed_files": ["database/000_baseline.sql", "database/010_mod.sql"]
# - 或嵌套 "database": { "seed_files": [...], "notes_zh": "本包与宿主 public 表的关系说明…" }
# 宿主仍为单一 DATABASE_URL；各 Mod 种子打到同一 PostgreSQL。物理分库请用不同 DATABASE_URL 分环境部署。

# --- 可选：进程级「只启用一个扩展包」（见 backend/shell/xcagi_mods_discover.py）---
# 设置后 GET /api/mods、/api/mods/routes、loading-status 中的磁盘扫描结果仅保留该 manifest id；
# 与浏览器请求头 X-XCAGI-Active-Mod-Id 二选一或同时存在（请求头优先）。
# XCAGI_SINGLE_MOD_ID=sz-qsm-pro

# --- 可选：业务读与扩展 Mod 绑定（见 backend/shell/mod_business_scope.py）---
# XCAGI 启动脚本 xcagi-backend-8000.cmd 默认设为 1：mods/*/manifest.json 中无任何「扩展型」包时，
# GET 产品列表/单位/客户与 document_templates 列表等返回空（库内不删数据）。
# FHD_BUSINESS_DATA_REQUIRES_EXTENSION_MOD=0

# Excel 工作区根目录（Planner / excel_analysis 相对路径基于此）
# WORKSPACE_ROOT=E:/FHD/workspace

# 与前端一致时，才注册并允许调用 products_bulk_import 写入 products / purchase_units
# 前端：VITE_DB_WRITE_TOKEN（构建时）或浏览器 localStorage「xcagi_db_write_token」
# 请求头：X-FHD-Db-Write-Token（管理端 bulk-import）；聊天 JSON 字段 db_write_token
# FHD_DB_WRITE_TOKEN=change-me-to-a-long-random-secret

# 一级只读锁默认开启：未设 FHD_DB_READ_TOKEN 时依次回退 FHD_DB_WRITE_TOKEN、内置默认值 61408693。
# 显式关闭（测试或旧行为）：FHD_DISABLE_DB_READ_LOCK=1
# 一级保护「产品库」只读 GET（/api/products/… 列表、单位、价表导出/预览等）以及 GET /api/sales-contract/template-preview（Word 首表预览），须 X-FHD-Db-Read-Token；客户/采购单位等多数 GET 不在此列。
# 二级：POST /api/products/add|update|delete|batch-delete 须 X-FHD-Db-Write-Token（须配置 FHD_DB_WRITE_TOKEN）。前端 localStorage：xcagi_db_read_token、xcagi_db_write_token。
# FHD_DB_READ_TOKEN=change-me-read-token
# 部署后自检: PowerShell 运行仓库 scripts/verify-db-read-lock.ps1

# AI 权限层 P1/P2：与 XCAGI 设置「开发者模式 + 提升口令」配合；请求头 X-XCAGI-AI-Tier / X-XCAGI-Elevated-Token
# FHD_AI_ELEVATED_TOKEN=change-me-elevated-secret
# 若客户端声明 P2 但口令错误：默认静默降为 P1；设为 1 则返回 403
# FHD_AI_TIER_STRICT=0
# POST /api/code-editor/apply/{id} 落盘须 P2（同上请求头 + 本口令）；POST /edit 与 GET /diff 不要求 P2。
# POST /edit 带 create_if_missing:true 可对「父目录已存在、path 尚不存在」的文本后缀路径生成新建提案（仍须 P2 apply）。
# POST /api/code-editor/draft 须 P2，且须已配置在线/离线 LLM；可选 FHD_CODE_EDITOR_DRAFT_CONTEXT_CHARS（默认 48000）限制注入模型的原文长度。
# 可选：公开模型注册表 JSON（GET /api/fhd/ai/models）
# FHD_PUBLIC_MODEL_REGISTRY_JSON=[{"id":"deepseek-chat","provider":"deepseek","label":"DeepSeek"}]


# 业务 Word 模板库：元数据在 PostgreSQL 表 ``document_templates``（见 scripts/pg_init_xcagi_core.sql），
# 启动时由 schema_auto_init 幂等建表/种子；前端 GET /api/document-templates，导出时传 template_id（即 slug）。
# 上传登记：POST /api/admin/document-templates（需 X-FHD-Db-Write-Token）。
#
# 模板预览（Excel/Word 网格、Planner 外非价表合同模板）：同一表 ``document_templates``，``role=excel_export``。
# REST：GET/PUT/DELETE /api/templates、POST /api/templates/create|update|delete；列表兼容 GET /api/templates/list。
# 旧 SQLite ``templates.db`` 仅用于一次性迁移：``python scripts/migrate_sqlite_templates_to_pg_document_templates.py``。
#
# document-templates 按角色筛选：price_list_docx | sales_contract_docx | excel_export；``role=excel_export`` 时可加 ``kind=word|excel``。
#
# 仅当 PG 中无可用行或文件缺失时，以下环境变量作为运维兜底（见 backend/document_template_service.py）：
# FHD_PRICE_LIST_DOCX_TEMPLATE=E:/FHD/424/document_templates/price_list_default.docx
# FHD_SALES_CONTRACT_TEMPLATE=E:/FHD/424/templates/我的销售合同模板.docx
# 亦可指向 .xls/.xlsx（与 document_templates 登记一致）；默认种子使用 424/document_templates/送货单.xls。

# 客户名 BGE 语义匹配（/api/customers/match 子串未命中时加载 sentence-transformers / torch）
# Windows 上默认 **关闭** 以避免 torch.distributed 日志与部分环境「无法找到入口」弹窗；
# 需要向量匹配购买单位时设为 1：FHD_ENABLE_CUSTOMER_SEMANTIC=1
# 任意平台强制关闭：FHD_DISABLE_CUSTOMER_SEMANTIC=1

# --- 可选：模型支付（微信 / 支付宝；未配置时接口仍返回套餐列表，下单为占位）---
# 微信支付 v3（示例变量名，具体以实现为准）
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_API_V3_KEY=
# 支付宝开放平台应用（电脑网站支付/当面付）
# ALIPAY_APP_ID=
# ALIPAY_APP_PRIVATE_KEY= 或 ALIPAY_APP_PRIVATE_KEY_PATH=（应用私钥，RSA256/PKCS8格式）
# ALIPAY_PUBLIC_KEY= 或 ALIPAY_PUBLIC_KEY_PATH=（支付宝公钥，从支付宝后台获取）
# ALIPAY_NOTIFY_URL=（可选，支付宝异步回调通知地址，如 https://your-domain.com/api/model-payment/alipay/notify）
