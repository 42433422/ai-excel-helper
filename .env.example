# Environment Configuration Template
# Copy this file to .env and fill in the values

# ===========================================
# Application Settings
# ===========================================
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-change-in-production

# ===========================================
# Mod 插件（关闭后不使用 mods/ 扩展蓝图与行业覆盖，仅核心 API + 原始 industry_config.yaml）
# ===========================================
# XCAGI_DISABLE_MODS=1

# ===========================================
# Database Settings
# ===========================================
# 主库：默认代码里是 PostgreSQL；复制本文件为 .env 后请按实际填写（不配则仍用 config 里的默认连接串）
# DATABASE_URL=postgresql+psycopg://用户名:密码@localhost:5432/数据库名
# 若仅用内置 SQLite 文件，可改为例如：
# DATABASE_URL=sqlite:///E:/FHD/XCAGI/data/your.db
DATABASE_PATH=/app/data

# ===========================================
# Redis / Cache Settings
# ===========================================
CACHE_REDIS_URL=redis://localhost:6379/0

# ===========================================
# Celery Settings
# ===========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===========================================
# Performance Optimization Settings (NEW)
# ===========================================

# --- 缓存配置 ---
XCAGI_DEFAULT_CACHE_TTL=300              # 默认缓存TTL(秒)
XCAGI_LOCAL_CACHE_SIZE=1000              # 本地L1缓存大小
XCAGI_LOCAL_CACHE_TTL=10                 # 本地L1缓存TTL(秒)
XCAGI_PRODUCT_CACHE_TTL=300              # 产品数据缓存TTL
XCAGI_PRODUCT_LIST_CACHE_TTL=60          # 产品列表缓存TTL(短)
XCAGI_AI_RESPONSE_CACHE_TTL=300          # AI响应缓存TTL
XCAGI_INTENT_CACHE_TTL=300               # 意图识别缓存TTL
XCAGI_CUSTOMER_CACHE_TTL=600             # 客户数据缓存TTL

# --- 异步任务配置 ---
XCAGI_TASK_DEFAULT_TIMEOUT=300           # 任务超时(秒)
XCAGI_TASK_MAX_RETRIES=3                 # 最大重试次数
XCAGI_TASK_RETRY_DELAY=5                 # 重试延迟(秒)
XCAGI_FORCE_SYNC_TASKS=0                 # 强制同步模式(调试用, 0=否 1=是)

# --- 性能监控配置 ---
XCAGI_SLOW_API_THRESHOLD=1000            # 慢API阈值(ms)
XCAGI_SLOW_QUERY_THRESHOLD=0.5           # 慢查询阈值(s)
XCAGI_PERF_HISTORY_SIZE=1000             # 性能历史记录数
XCAGI_MEMORY_WARNING=512                 # 内存警告阈值(MB)

# --- 请求去重配置 ---
XCAGI_DEDUP_WINDOW=60                    # 去重时间窗口(秒)
XCAGI_DEDUP_MAX_KEYS=10000               # 最大去重键数

# --- 限流配置 ---
XCAGI_DEFAULT_RATE_LIMIT=100             # 默认限流(次/分钟/用户)
XCAGI_AI_RATE_LIMIT=30                   # AI接口限流(次/分钟)
XCAGI_UPLOAD_RATE_LIMIT=10               # 文件上传限流(次/分钟)

# --- 熔断器配置 ---
XCAGI_CIRCUIT_FAILURE_THRESHOLD=5        # 失败触发熔断的次数
XCAGI_CIRCUIT_RECOVERY_TIMEOUT=60         # 熔断恢复等待时间(秒)

# ===========================================
# File Upload Settings
# ===========================================
UPLOAD_FOLDER=/app/uploads
MAX_CONTENT_LENGTH=16777216

# ===========================================
# Logging Settings
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# AI/ML Settings (Optional)
# ===========================================
# OPENAI_API_KEY=your-openai-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key

# ===========================================
# WeChat Settings (Optional)
# ===========================================
# WECHAT_APP_ID=your-wechat-app-id
# WECHAT_APP_SECRET=your-wechat-app-secret
