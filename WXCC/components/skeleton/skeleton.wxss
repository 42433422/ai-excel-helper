/* 骨架屏样式 */
.skeleton-wrapper {
  width: 100%;
}

.skeleton-list,
.skeleton-cart {
  padding: 20rpx;
}

.skeleton-item,
.skeleton-cart-item {
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  animation: shimmer 1.5s infinite;
}

/* 列表骨架屏 */
.skeleton-image {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.skeleton-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.skeleton-title {
  width: 80%;
  height: 32rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 4rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-desc {
  width: 60%;
  height: 24rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 4rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.skeleton-price {
  width: 120rpx;
  height: 36rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 4rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-sales {
  width: 80rpx;
  height: 24rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 4rpx;
  animation: shimmer 1.5s infinite;
}

/* 详情骨架屏 */
.skeleton-banner {
  width: 100%;
  height: 750rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skeleton-info {
  padding: 30rpx;
}

.skeleton-price-lg {
  width: 200rpx;
  height: 48rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-name {
  width: 90%;
  height: 36rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-desc-sm {
  width: 70%;
  height: 28rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 4rpx;
  animation: shimmer 1.5s infinite;
}

/* 购物车骨架屏 */
.skeleton-checkbox {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 50%;
  margin-right: 20rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-cart-image {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 12rpx;
  flex-shrink: 0;
  animation: shimmer 1.5s infinite;
}

.skeleton-cart-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.skeleton-cart-title {
  width: 80%;
  height: 32rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 4rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-cart-price {
  width: 140rpx;
  height: 36rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 4rpx;
  animation: shimmer 1.5s infinite;
}

/* 闪烁动画 */
@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}
