/* 图表容器 */
.chart-container {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 30rpx;
  text-align: center;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

/* 柱状图样式 */
.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 200rpx;
  padding: 0 20rpx;
}

.chart-bar {
  position: relative;
  width: 40rpx;
  border-radius: 8rpx 8rpx 0 0;
  transition: all 0.3s ease;
  background: linear-gradient(to top, #1890ff, #52c41a);
  box-shadow: 0 4rpx 16rpx rgba(24, 144, 255, 0.4);
}

.chart-bar:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.6);
}

.bar-value {
  position: absolute;
  top: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.bar-label {
  position: absolute;
  bottom: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  white-space: nowrap;
}

/* 环形图样式 */
.pie-chart {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pie-container {
  position: relative;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  overflow: hidden;
}

.pie-segment {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  clip-path: polygon(50% 50%, 50% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%);
}

.pie-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60%;
  height: 60%;
  background: #1a1a1a;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.pie-total {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

.pie-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

.pie-legend {
  margin-top: 30rpx;
  width: 100%;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.legend-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 数据卡片样式 */
.data-card {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
}

.data-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.card-trend {
  font-size: 24rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.trend-up {
  background: rgba(82, 196, 26, 0.2);
  color: #52c41a;
}

.trend-down {
  background: rgba(245, 34, 45, 0.2);
  color: #f5222d;
}

.trend-stable {
  background: rgba(250, 173, 20, 0.2);
  color: #faad14;
}

.card-content {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.card-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.card-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-left: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}