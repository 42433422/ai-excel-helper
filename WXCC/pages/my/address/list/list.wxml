<view class="container">
  <!-- 地址列表 -->
  <view class="address-list" wx:if="{{addresses.length > 0}}">
    <view class="address-item card" wx:for="{{addresses}}" wx:key="id">
      <view class="address-content" bindtap="selectAddress" data-id="{{item.id}}">
        <view class="address-header">
          <text class="address-name">{{item.name}}</text>
          <text class="address-phone">{{item.phone}}</text>
          <view class="default-tag" wx:if="{{item.isDefault}}">默认</view>
        </view>
        <view class="address-detail">
          <text class="iconfont icon-location"></text>
          <text>{{item.detail}}</text>
        </view>
      </view>
      <view class="address-actions">
        <view class="action-btn" bindtap="editAddress" data-id="{{item.id}}">
          <text class="iconfont icon-edit"></text>
        </view>
        <view class="action-btn" bindtap="deleteAddress" data-id="{{item.id}}">
          <text class="iconfont icon-delete"></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{addresses.length === 0}}">
    <image src="/assets/empty-address.png" mode="aspectFit"></image>
    <text class="empty-text">暂无收货地址</text>
  </view>

  <!-- 添加地址按钮 -->
  <view class="add-address-btn" bindtap="addAddress">
    <text class="iconfont icon-plus"></text>
    <text>新增地址</text>
  </view>
</view>
