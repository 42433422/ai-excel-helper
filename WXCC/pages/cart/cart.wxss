/* 购物车页面样式 */
.container {
  padding: 20rpx;
  padding-bottom: 140rpx;
  background-color: #f5f5f5;
}

/* 购物车列表 */
.cart-list {
  margin-bottom: 20rpx;
}

.cart-item {
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.item-checkbox {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
}

.item-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-image image {
  width: 100%;
  height: 100%;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-spec {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.item-price {
  font-size: 32rpx;
  color: #f5222d;
  font-weight: bold;
}

.item-quantity {
  display: flex;
  align-items: center;
  border: 1rpx solid #e8e8e8;
  border-radius: 4rpx;
}

.quantity-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
}

.quantity-btn:active {
  background-color: #f5f5f5;
}

.quantity-value {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.item-delete {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  margin-left: 16rpx;
}

.item-delete .iconfont {
  font-size: 36rpx;
  color: #999;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.select-all {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.select-text {
  font-size: 28rpx;
  color: #333;
  margin-left: 12rpx;
}

.total-section {
  flex: 1;
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
}

.total-text {
  font-size: 28rpx;
  color: #333;
}

.total-price {
  font-size: 36rpx;
  color: #f5222d;
  font-weight: bold;
}

.btn-checkout {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  margin-left: 20rpx;
  font-weight: bold;
}

.btn-checkout:active {
  opacity: 0.8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-state image {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}
