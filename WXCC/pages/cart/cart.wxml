<view class="container">
  <!-- 购物车列表 -->
  <view class="cart-list" wx:if="{{cartItems.length > 0}}">
    <view class="cart-item card" wx:for="{{cartItems}}" wx:key="id">
      <view class="item-checkbox">
        <checkbox 
          checked="{{item.checked}}" 
          bindtap="toggleCheck" 
          data-index="{{index}}"
          color="#1890ff"
        />
      </view>
      <view class="item-image" bindtap="goToProduct" data-id="{{item.productId}}">
        <image src="{{item.image}}" mode="aspectFill"></image>
      </view>
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-spec">{{item.spec}}</text>
        <view class="item-bottom">
          <text class="item-price">¥{{item.price}}</text>
          <view class="item-quantity">
            <view class="quantity-btn" bindtap="decreaseQuantity" data-index="{{index}}">-</view>
            <text class="quantity-value">{{item.quantity}}</text>
            <view class="quantity-btn" bindtap="increaseQuantity" data-index="{{index}}">+</view>
          </view>
        </view>
      </view>
      <view class="item-delete" bindtap="deleteItem" data-index="{{index}}">
        <text class="iconfont icon-delete"></text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{cartItems.length === 0}}">
    <image src="/assets/empty-cart.png" mode="aspectFit"></image>
    <text class="empty-text">购物车空空如也</text>
    <view class="btn-primary" bindtap="goShopping">去逛逛</view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar safe-area-bottom" wx:if="{{cartItems.length > 0}}">
    <view class="select-all" bindtap="toggleSelectAll">
      <checkbox checked="{{selectAll}}" color="#1890ff" />
      <text class="select-text">全选</text>
    </view>
    <view class="total-section">
      <text class="total-text">合计：</text>
      <text class="total-price">¥{{totalPrice}}</text>
    </view>
    <view class="btn-checkout" bindtap="checkout">
      结算 ({{selectedCount}})
    </view>
  </view>
</view>
