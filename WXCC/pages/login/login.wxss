/* 登录页面样式 */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 60rpx 40rpx;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

/* 登录表单 */
.login-form {
  width: 100%;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #333;
}

.code-wrapper {
  display: flex;
  align-items: center;
}

.code-input {
  flex: 1;
  margin-right: 20rpx;
}

.send-code-btn {
  background-color: #fff;
  color: #1890ff;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  font-size: 26rpx;
  font-weight: bold;
  border: none;
  white-space: nowrap;
}

.send-code-btn.disabled {
  background-color: rgba(255, 255, 255, 0.5);
  color: rgba(24, 144, 255, 0.5);
}

/* 登录按钮 */
.login-actions {
  width: 100%;
}

.btn-login,
.btn-wechat {
  width: 100%;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border: none;
}

.btn-login {
  background-color: #fff;
  color: #1890ff;
}

.btn-wechat {
  background-color: #07c160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-wechat .iconfont {
  margin-right: 12rpx;
  font-size: 36rpx;
}

/* 协议 */
.agreement {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 40rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.agreement-link {
  font-size: 24rpx;
  color: #fff;
  text-decoration: underline;
}
