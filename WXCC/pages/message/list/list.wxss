/* 消息列表页面样式 */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
}

/* 消息列表 */
.message-list {
  margin-bottom: 20rpx;
}

.message-item {
  display: flex;
  align-items: flex-start;
  padding: 30rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.message-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.message-icon.order {
  background-color: #e6f7ff;
  color: #1890ff;
}

.message-icon.system {
  background-color: #f6ffed;
  color: #52c41a;
}

.message-icon.promotion {
  background-color: #fff7e6;
  color: #faad14;
}

.message-icon.logistics {
  background-color: #f9f0ff;
  color: #722ed1;
}

.message-icon .iconfont {
  font-size: 40rpx;
}

.message-content {
  flex: 1;
  overflow: hidden;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.message-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.message-time {
  font-size: 24rpx;
  color: #999;
}

.message-desc {
  font-size: 28rpx;
  color: #666;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-badge {
  width: 16rpx;
  height: 16rpx;
  background-color: #f5222d;
  border-radius: 50%;
  position: absolute;
  top: 30rpx;
  right: 30rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-state image {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}
