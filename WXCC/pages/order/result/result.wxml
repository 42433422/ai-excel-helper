<view class="container">
  <view class="result-card card">
    <view class="result-icon {{status === 'success' ? 'success' : 'fail'}}">
      <text class="iconfont {{status === 'success' ? 'icon-check' : 'icon-close'}}"></text>
    </view>
    <text class="result-title">{{resultTitle}}</text>
    <text class="result-desc">{{resultDesc}}</text>
    
    <view class="order-info">
      <text class="order-label">订单号：</text>
      <text class="order-number">{{orderId}}</text>
      <text class="iconfont icon-copy" bindtap="copyOrderId"></text>
    </view>
    
    <view class="result-actions">
      <view class="btn-secondary" bindtap="goToOrders" wx:if="{{status === 'success'}}">查看订单</view>
      <view class="btn-primary" bindtap="goToIndex" wx:if="{{status === 'success'}}">继续购物</view>
      <view class="btn-primary" bindtap="retry" wx:else>重新下单</view>
    </view>
  </view>
</view>
