/* 订单详情页面样式 */
.container {
  padding: 20rpx;
  padding-bottom: 140rpx;
  background-color: #f5f5f5;
}

/* 订单状态 */
.order-status {
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
}

.status-header {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

.status-actions {
  display: flex;
  justify-content: flex-end;
  padding: 0 30rpx 30rpx;
  gap: 20rpx;
}

.action-btn {
  padding: 16rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  border: none;
}

.action-btn.secondary {
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.action-btn.primary {
  background-color: #fff;
  color: #1890ff;
}

/* 商品信息 */
.product-section {
  margin-bottom: 20rpx;
}

.product-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-spec {
  font-size: 24rpx;
  color: #999;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #f5222d;
}

.product-quantity {
  font-size: 26rpx;
  color: #999;
}

/* 订单信息 */
.order-info {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

/* 收货地址 */
.address-section {
  margin-bottom: 20rpx;
}

.address-content {
  display: flex;
  flex-direction: column;
}

.address-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.address-detail {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 金额明细 */
.amount-section {
  margin-bottom: 20rpx;
}

.amount-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.amount-label {
  font-size: 28rpx;
  color: #666;
}

.amount-value {
  font-size: 28rpx;
  color: #333;
}

.amount-item.total {
  border-top: 1rpx solid #f0f0f0;
  margin-top: 10rpx;
  padding-top: 20rpx;
}

.amount-item.total .amount-label {
  font-weight: bold;
  color: #333;
}

.amount-item.total .total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #f5222d;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: flex-end;
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.bar-btn {
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  background-color: #fff;
  color: #333;
  border: 2rpx solid #f0f0f0;
}

.bar-btn.primary {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border: none;
}
