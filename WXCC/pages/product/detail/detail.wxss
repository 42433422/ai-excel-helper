/* 商品详情页样式 */
.container {
  padding-bottom: 120rpx;
  background-color: #f5f5f5;
}

/* 商品图片 */
.product-images {
  background-color: #fff;
  margin-bottom: 20rpx;
}

.image-swiper {
  height: 700rpx;
}

.product-image {
  width: 100%;
  height: 100%;
}

/* 商品信息 */
.product-info {
  margin: 20rpx;
  padding: 30rpx;
}

.price-section {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.price {
  font-size: 48rpx;
  color: #f5222d;
  font-weight: bold;
}

.original-price {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.product-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.product-meta {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #e8e8e8;
}

.meta-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.meta-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.meta-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

/* 规格选择 */
.spec-section {
  margin: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.spec-list {
  display: flex;
  flex-wrap: wrap;
}

.spec-item {
  padding: 16rpx 32rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s;
}

.spec-item.active {
  border-color: #1890ff;
  background-color: #e6f7ff;
  color: #1890ff;
}

/* 商品详情 */
.detail-section {
  margin: 20rpx;
  padding: 30rpx;
}

.detail-content {
  background-color: #fff;
}

.detail-content image {
  width: 100%;
  height: auto;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 30rpx;
  position: relative;
}

.action-item .iconfont {
  font-size: 40rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.action-text {
  font-size: 22rpx;
  color: #666;
}

.btn-buy {
  flex: 1;
  background: linear-gradient(135deg, #f5222d 0%, #ff4d4f 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  text-align: center;
  font-weight: bold;
}

.btn-buy:active {
  opacity: 0.8;
}

/* 徽章 */
.badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: #f5222d;
  color: #fff;
  border-radius: 20rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  min-width: 32rpx;
  text-align: center;
}
