.dashboard-container {
  padding: 20rpx;
  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
  min-height: 100vh;
}

.stats-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 30rpx;
  text-align: center;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

/* 订单监控样式 */
.order-monitor {
  max-height: 400rpx;
  overflow-y: auto;
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.order-item:last-child {
  border-bottom: none;
}

.order-info {
  display: flex;
  flex-direction: column;
}

.order-id {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

.order-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4rpx;
}

.order-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.order-status.pending {
  background: rgba(250, 173, 20, 0.2);
  color: #faad14;
}

.order-status.shipping {
  background: rgba(24, 144, 255, 0.2);
  color: #1890ff;
}

.order-status.completed {
  background: rgba(82, 196, 26, 0.2);
  color: #52c41a;
}

/* 性能监控样式 */
.performance-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.performance-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.perf-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  min-width: 120rpx;
}

.perf-value {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  min-width: 80rpx;
  text-align: right;
}

/* 推荐统计样式 */
.recommend-stats {
  display: flex;
  justify-content: space-around;
  text-align: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 自定义组件样式覆盖 */
.tech-progress {
  flex: 1;
  margin: 0;
}

/* 滚动条样式 */
.order-monitor::-webkit-scrollbar {
  width: 4rpx;
}

.order-monitor::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 2rpx;
}

.order-monitor::-webkit-scrollbar-thumb {
  background: rgba(24, 144, 255, 0.5);
  border-radius: 2rpx;
}

.order-monitor::-webkit-scrollbar-thumb:hover {
  background: rgba(24, 144, 255, 0.8);
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .stats-row {
    flex-direction: column;
  }
  
  .recommend-stats {
    flex-direction: column;
    gap: 30rpx;
  }
}

/* 动画效果 */
@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.tech-card {
  animation: slideIn 0.6s ease-out;
}

.tech-card:nth-child(1) { animation-delay: 0.1s; }
.tech-card:nth-child(2) { animation-delay: 0.2s; }
.tech-card:nth-child(3) { animation-delay: 0.3s; }
.tech-card:nth-child(4) { animation-delay: 0.4s; }