<view class="container">
  <view class="category-layout">
    <!-- 左侧分类列表 -->
    <view class="category-sidebar">
      <scroll-view class="sidebar-scroll" scroll-y="{{true}}">
        <view 
          class="sidebar-item {{currentCategory === item.id ? 'active' : ''}}" 
          wx:for="{{categories}}" 
          wx:key="id"
          bindtap="selectCategory"
          data-id="{{item.id}}"
        >
          <text class="sidebar-text">{{item.name}}</text>
        </view>
      </scroll-view>
    </view>

    <!-- 右侧商品列表 -->
    <view class="category-content">
      <scroll-view class="content-scroll" scroll-y="{{true}}" bindscrolltolower="loadMore">
        <view class="product-grid">
          <view 
            class="product-card" 
            wx:for="{{products}}" 
            wx:key="id"
            bindtap="goToProduct"
            data-id="{{item.id}}"
          >
            <image class="product-image" src="{{item.image}}" mode="aspectFill"></image>
            <view class="product-info">
              <text class="product-name">{{item.name}}</text>
              <text class="product-desc">{{item.description}}</text>
              <text class="product-price">¥{{item.price}}</text>
            </view>
          </view>
        </view>

        <!-- 加载更多 -->
        <view class="load-more" wx:if="{{hasMore}}">
          <text>加载更多...</text>
        </view>

        <!-- 空状态 -->
        <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
          <image src="https://placehold.co/200x200/f5f5f5/cccccc?text=No+Data" mode="aspectFit"></image>
          <text>暂无商品</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
