/* AI聊天容器 */
.ai-chat-container {
  height: 100vh;
  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
  display: flex;
  flex-direction: column;
}

/* 聊天头部 */
.chat-header {
  background: rgba(26, 26, 26, 0.9);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ai-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff, #52c41a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.3);
}

.ai-icon {
  font-size: 40rpx;
}

.header-info {
  display: flex;
  flex-direction: column;
}

.ai-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.ai-status {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4rpx;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 32rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
}

.action-btn:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.95);
}

/* 聊天内容 */
.chat-messages {
  flex: 1;
  padding: 30rpx;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.message-item {
  display: flex;
  gap: 20rpx;
  animation: messageSlide 0.3s ease-out;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-icon {
  font-size: 28rpx;
}

.message-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.message-item.user .message-content {
  align-items: flex-end;
}

.message-bubble {
  max-width: 70%;
  padding: 20rpx 30rpx;
  border-radius: 24rpx;
  position: relative;
  word-wrap: break-word;
}

.message-item.assistant .message-bubble {
  background: rgba(255, 255, 255, 0.1);
  border-top-left-radius: 8rpx;
}

.message-item.user .message-bubble {
  background: linear-gradient(135deg, #1890ff, #52c41a);
  border-top-right-radius: 8rpx;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #ffffff;
}

.message-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

.message-actions {
  display: flex;
  gap: 16rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.message-item.assistant:hover .message-actions {
  opacity: 1;
}

/* AI思考指示器 */
.thinking-indicator {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  border-top-left-radius: 8rpx;
  max-width: 200rpx;
}

.thinking-dots {
  display: flex;
  gap: 4rpx;
}

.thinking-dot {
  font-size: 32rpx;
  color: #1890ff;
  animation: thinkingDot 1.4s infinite;
}

.thinking-dot:nth-child(2) { animation-delay: 0.2s; }
.thinking-dot:nth-child(3) { animation-delay: 0.4s; }

.thinking-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 快捷问题 */
.quick-questions {
  padding: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.questions-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
  text-align: center;
}

.questions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.question-item {
  background: rgba(255, 255, 255, 0.1);
  padding: 20rpx;
  border-radius: 16rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.question-item:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.98);
}

.question-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

/* 输入区域 */
.input-area {
  background: rgba(26, 26, 26, 0.9);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 30rpx;
}

.input-container {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 20rpx;
}

.message-input {
  flex: 1;
  min-height: 80rpx;
  max-height: 200rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: transparent;
  border: none;
  outline: none;
}

.message-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.input-actions {
  display: flex;
  align-items: center;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  transition: all 0.3s ease;
}

.send-btn.active {
  background: linear-gradient(135deg, #1890ff, #52c41a);
  transform: scale(1.1);
}

.send-btn:active {
  transform: scale(0.95);
}

/* 动画 */
@keyframes messageSlide {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes thinkingDot {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.5;
  }
  30% {
    transform: translateY(-10rpx);
    opacity: 1;
  }
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .questions-grid {
    grid-template-columns: 1fr;
  }
  
  .message-bubble {
    max-width: 85%;
  }
}

/* 滚动条样式 */
.chat-messages::-webkit-scrollbar {
  width: 4rpx;
}

.chat-messages::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.1);
}

.chat-messages::-webkit-scrollbar-thumb {
  background: rgba(24, 144, 255, 0.5);
  border-radius: 2rpx;
}