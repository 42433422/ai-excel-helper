[flake8]
max-line-length = 100
max-complexity = 10
ignore = 
    E501
    W503
    E203
    E402
    C901
exclude = 
    .git
    __pycache__
    .venv
    venv
    node_modules
    frontend
    build
    dist
    *.egg-info
    .eggs
    migrations
    alembic/versions
per-file-ignores =
    __init__.py: F401
